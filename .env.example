# =============================================================================
# PESU Academy Slide Downloader — environment configuration
# =============================================================================
# Copy this file to ".env" and fill in your values:
#     cp .env.example .env
#
# The .env file is read ONLY by the CLI (src/cli/index.js) and the legacy
# wrapper script (scripts/pesu-agent.js) via dotenv. The Electron desktop app
# collects credentials from its UI at runtime and does NOT read this file.
# .env is git-ignored and never bundled into packaged builds.
# =============================================================================

# Your PESU Academy login (SRN / PRN / username).
# Used as the default when --username is not passed on the CLI.
PESU_USERNAME=your_pesu_username

# Your PESU Academy password.
# Used as the default when --password is not passed on the CLI.
# Keep this file private; credentials are only used for the active run.
PESU_PASSWORD=your_pesu_password

# -----------------------------------------------------------------------------
# Optional tuning variables (uncomment to override defaults)
# -----------------------------------------------------------------------------

# Delay in milliseconds between browser actions, read by src/core/downloader.js.
# Overrides the built-in default (800 ms, or 1400 ms when PWDEBUG is set).
# Note: the CLI --speed / --delay-ms flags and the desktop speed selector pass
# their own value programmatically and take precedence over this variable.
# PESU_AGENT_DELAY_MS=800

# Set to 1 to enable Playwright's inspector / debug mode (used by the
# "pesu:debug" and "pesu:agent:debug" npm scripts). When set, the default
# action delay becomes 1400 ms for easier step-through debugging.
# PWDEBUG=1

# Override the directory Playwright uses to locate its managed Chromium bundle.
# This is normally set automatically by scripts/install-playwright-chromium.js
# and src/core/browserResolver.js — only set it manually for custom setups.
# PLAYWRIGHT_BROWSERS_PATH=./playwright-browsers
